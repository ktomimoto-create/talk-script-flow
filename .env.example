# Microsoft Entra ID (Azure AD) の SSO 設定
# このファイルを .env.local にコピーして、実際の値を入れてください。
# .env.local は .gitignore で除外されます（コミット禁止）。

# Entra ID のアプリ登録で発行される「アプリケーション (クライアント) ID」
VITE_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# 同じく「ディレクトリ (テナント) ID」
VITE_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# リダイレクト URI（省略時は現在の origin を使用）
# 開発時: http://localhost:5177
# 本番時: https://your-domain.example.com
VITE_AZURE_REDIRECT_URI=http://localhost:5177

# Firebase 設定 (Cloud Firestore用)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Supabase 設定
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
